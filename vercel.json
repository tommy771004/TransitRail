{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": "src/data/scraped/**"
    },
    "api/sitemap.ts": {
      "includeFiles": "{src/data/scraped/**,scripts/lib/**}"
    }
  },
  "headers": [
    {
      "source": "/sitemaps/(.*)\\.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Content-Disposition",
          "value": "inline"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/sitemap",
      "destination": "https://rail-national.vercel.app/sitemap.xml",
      "permanent": true
    },
    {
      "source": "/sitemap/",
      "destination": "https://rail-national.vercel.app/sitemap.xml",
      "permanent": true
    },
    {
      "source": "/sitemap.html",
      "destination": "https://rail-national.vercel.app/sitemap.xml",
      "permanent": true
    },
    {
      "source": "/sitemap-index.xml",
      "destination": "https://rail-national.vercel.app/sitemap.xml",
      "permanent": true
    },
    {
      "source": "/sitemap_index.xml",
      "destination": "https://rail-national.vercel.app/sitemap.xml",
      "permanent": true
    },
    {
      "source": "/Sitemap",
      "destination": "https://rail-national.vercel.app/sitemap.xml",
      "permanent": true
    },
    {
      "source": "/Sitemap/",
      "destination": "https://rail-national.vercel.app/sitemap.xml",
      "permanent": true
    },
    {
      "source": "/sitemaps",
      "destination": "https://rail-national.vercel.app/sitemap.xml",
      "permanent": true
    },
    {
      "source": "/sitemaps/",
      "destination": "https://rail-national.vercel.app/sitemap.xml",
      "permanent": true
    },
    {
      "source": "/Sitemaps",
      "destination": "https://rail-national.vercel.app/sitemap.xml",
      "permanent": true
    },
    {
      "source": "/Sitemaps/",
      "destination": "https://rail-national.vercel.app/sitemap.xml",
      "permanent": true
    },
    {
      "source": "/Sitemaps/core.xml",
      "destination": "https://rail-national.vercel.app/sitemaps/core.xml",
      "permanent": true
    },
    {
      "source": "/Sitemaps/countries.xml",
      "destination": "https://rail-national.vercel.app/sitemaps/countries.xml",
      "permanent": true
    },
    {
      "source": "/Sitemaps/routes.xml",
      "destination": "https://rail-national.vercel.app/sitemaps/routes.xml",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/Sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
