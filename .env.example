# Switzerland / OpenTransportData Swiss
SWISS_OJP_URL=https://api.opentransportdata.swiss/ojp20
SWISS_OJP_TOKEN=
SWISS_OJP_REQUESTOR_REF=TransitRail_prod

# Reserved for next integration steps
SWISS_OJP_FARE_URL=https://api.opentransportdata.swiss/ojpfare
SWISS_OJP_FARE_TOKEN=

SWISS_SIRI_SX_URL=https://api.opentransportdata.swiss/la/siri-sx
SWISS_SIRI_SX_TOKEN=

SWISS_SIRI_SX_UNPLANNED_URL=https://api.opentransportdata.swiss/la/siri-sx-unplanned
SWISS_SIRI_SX_UNPLANNED_TOKEN=

SWISS_SIRI_ET_URL=https://api.opentransportdata.swiss/la/siri-et
SWISS_SIRI_ET_TOKEN=

SWISS_FORMATION_URL=https://api.opentransportdata.swiss/formation/v1
SWISS_FORMATION_TOKEN=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Japan Transit API (Open Data Public Transportation)
# Get a free key at: https://developer.odpt.org/
ODPT_API_KEY=""

# Korea Transit API (ODsay)
# Get a free key at: https://lab.odsay.com/
ODSAY_API_KEY=""

# Hong Kong MTR Next Train does not require an API key.

# London TfL Unified API. Anonymous access is supported at a lower rate,
# but production deployments should configure an app key.
TFL_APP_KEY=""

# Boston MBTA V3 API. Anonymous access is available with stricter rate limits.
MBTA_API_KEY=""

# Planned provider adapters. These credentials are not used until the
# corresponding country adapter is added.
LTA_ACCOUNT_KEY=""
DB_CLIENT_ID=""
DB_API_KEY=""
SWISS_TRANSPORT_TOKEN=""
SF_511_API_KEY=""

OPENROUTER_API_KEY=""

# Database connection URL (e.g. for Neon or Cloud SQL)
DATABASE_URL=""

# Web Push (schedule-change notifications for saved routes).
# Requires DATABASE_URL — subscriptions are stored in the push_subscriptions
# table (src/db/schema.ts) so scripts/check-push-notifications.ts can find them.
# Generate a keypair once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# Contact address the push service can reach you at if it flags your traffic.
VAPID_SUBJECT="mailto:you@example.com"

# Cross-project telemetry (server-only)
# Set these in Vercel Project Settings for both Production and Preview.
# TELEMETRY_PROJECT_KEY must exactly match a key in the Admin Console's
# TELEMETRY_INGEST_KEYS JSON object. Never expose TELEMETRY_INGEST_KEY to Vite,
# React, HTML, or any browser request.
TELEMETRY_INGEST_URL=""
TELEMETRY_PROJECT_KEY=""
TELEMETRY_INGEST_KEY=""
