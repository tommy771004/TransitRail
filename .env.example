# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Japan Transit API (Open Data Public Transportation)
# Get a free key at: https://developer.odpt.org/
ODPT_API_KEY=""

# Korea Transit API (ODsay)
# Get a free key at: https://lab.odsay.com/
ODSAY_API_KEY=""

# Hong Kong MTR Next Train does not require an API key.

# London TfL Unified API. Anonymous access is supported at a lower rate,
# but production deployments should configure an app key.
TFL_APP_KEY=""

# Boston MBTA V3 API. Anonymous access is available with stricter rate limits.
MBTA_API_KEY=""

# OpenRouter — authoring-time only, used by the curated-snapshot transfer
# cross-check (scripts/seed-curated-snapshots.ts -> scripts/lib/llmTransfer.ts).
# Leave blank to skip it: without a key the LLM cross-check is inert and the
# curated interchanges stand. NEVER used by the app or the daily scraper.
OPENROUTER_API_KEY=""
# Set to "true" to let the cross-check fall back to PAID models when the free
# pool fails. Off by default (free models only).
ALLOW_PAID_FALLBACK=""

# Planned provider adapters. These credentials are not used until the
# corresponding country adapter is added.
LTA_ACCOUNT_KEY=""
DB_CLIENT_ID=""
DB_API_KEY=""
SWISS_TRANSPORT_TOKEN=""
SF_511_API_KEY=""
