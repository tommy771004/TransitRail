{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "scrape": "tsx scripts/scrape-all.ts",
    "scrape:japan": "tsx -e \"import { JapanScraper } from './scripts/scrapers/japan'; new JapanScraper().runAll(new Date().toISOString().split('T')[0]).then(r => { console.log(r.length, 'routes done'); process.exit(0); })\"",
    "scrape:korea": "tsx -e \"import { KoreaScraper } from './scripts/scrapers/korea'; new KoreaScraper().runAll(new Date().toISOString().split('T')[0]).then(r => { console.log(r.length, 'routes done'); process.exit(0); })\"",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "d3": "^7.9.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "i18next": "^26.3.3",
    "idb-keyval": "^6.2.6",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-i18next": "^17.0.8",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.20.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.23.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
